{
  "name": "mfe-shell-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mfe-shell-angular/src",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/mfe-shell-angular",
        "index": "apps/mfe-shell-angular/src/index.html",
        "main": "apps/mfe-shell-angular/src/main.ts",
        "polyfills": ["zone.js", "@angular/localize/init"],
        "tsConfig": "apps/mfe-shell-angular/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mfe-shell-angular/public",
            "output": "."
          }
        ],
        "styles": [
          "@angular/material/prebuilt-themes/azure-blue.css",
          "apps/mfe-shell-angular/src/styles.scss"
        ],
        "scripts": ["node_modules/apexcharts/dist/apexcharts.min.js"],
        "customWebpackConfig": {
          "path": "apps/mfe-shell-angular/webpack.config.ts"
        },
        "stylePreprocessorOptions": {
          "includePaths": ["libs/shared/ui/src/lib/ui/styles"]
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "1MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kB",
              "maximumError": "4kB"
            }
          ],
          "outputHashing": "all",
          "customWebpackConfig": {
            "path": "apps/mfe-shell-angular/webpack.prod.config.ts"
          }
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": {
            "scripts": true,
            "styles": true,
            "hidden": false,
            "vendor": false
          }
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@nx/angular:module-federation-dev-server",
      "options": {
        "port": 4200,
        "publicHost": "http://localhost:4200"
      },
      "configurations": {
        "production": {
          "buildTarget": "mfe-shell-angular:build:production"
        },
        "development": {
          "buildTarget": "mfe-shell-angular:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular-devkit/build-angular:karma",
      "options": {
        "polyfills": ["zone.js", "zone.js/testing", "@angular/localize/init"],
        "tsConfig": "apps/mfe-shell-angular/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/mfe-shell-angular/public",
            "output": "."
          }
        ],
        "styles": ["apps/mfe-shell-angular/src/styles.scss"],
        "scripts": []
      }
    }
  }
}
