{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@micro-expense-tracker/shared/types": ["libs/shared/types/src/index.ts"],
      "@micro-expense-tracker/shared/utils": ["libs/shared/utils/src/index.ts"],
      "@micro-expense-tracker/shared/data-access": [
        "libs/shared/data-access/src/index.ts"
      ],
      "@micro-expense-tracker/auth/data-access": [
        "libs/auth/data-access/src/index.ts"
      ],
      "@micro-expense-tracker/shared/ui": ["libs/shared/ui/src/index.ts"],
      "@micro-expense-tracker/auth/features": [
        "libs/auth/features/src/index.ts"
      ],
      "@micro-expense-tracker/shared/constants": [
        "libs/shared/constants/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
