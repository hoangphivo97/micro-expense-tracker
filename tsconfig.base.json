{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@micro-expense-tracker/shared/types": [
        "./libs/shared/types/src/index.ts"
      ],
      "@micro-expense-tracker/shared/utils": [
        "./libs/shared/utils/src/index.ts"
      ],
      "@micro-expense-tracker/shared/data-access": [
        "./libs/shared/data-access/src/index.ts"
      ],
      "@micro-expense-tracker/auth/data-access": [
        "./libs/auth/data-access/src/index.ts"
      ],
      "@micro-expense-tracker/shared/ui": ["./libs/shared/ui/src/index.ts"],
      "@micro-expense-tracker/auth/features": [
        "./libs/auth/features/src/index.ts"
      ],
      "@micro-expense-tracker/shared/constants": [
        "./libs/shared/constants/src/index.ts"
      ],
      "@micro-expense-tracker/expenses/data-access": [
        "./libs/expenses/data-access/src/index.ts"
      ],
      "@micro-expense-tracker/expenses/features": [
        "./libs/expenses/features/src/index.ts"
      ],
      "utils": ["./libs/expenses/utils/src/index.ts"],
      "@micro-expense-tracker/backend/auth/data-access": [
        "./libs/auth/data-access-backend/src/index.ts"
      ],
      "@micro-expense-tracker/backend/auth/features": [
        "./libs/auth/features-backend/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
